{
  "name": "@ukhsa-collaboration/spectral-rules",
  "version": "0.4.1",
  "description": "UKHSA OpenAPI lint ruleset",
  "main": "ukhsa.oas.rules.yml",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "fmt:md": "remark . --ext .md --output",
    "lint:md": "remark . --ext .md --frail",
    "pretest": "npm run build && npm run build:functions:cjs",
    "pretest:watch": "npm run build && npm run build:functions:cjs",
    "prepare": "husky && git config commit.template .gitmessage",
    "start": "docker run --rm --pull=always -p \"8080:8080\" -v \"./docs:/site/docs/api-design-guidelines\" ghcr.io/ukhsa-collaboration/standards-org:latest",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "build:functions:cjs": "tsc -p tsconfig.vacuum.json && node scripts/build-vacuum-functions.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ukhsa-collaboration/standards-api.git"
  },
  "homepage": "https://ukhsa-collaboration.github.io/standards-org/api-design-guidelines/",
  "license": "MIT",
  "engines": {
    "npm": ">=10",
    "node": ">=22.21.0 <23"
  },
  "keywords": [
    "UKHSA",
    "ruleset",
    "vacuum"
  ],
  "dependencies": {
    "@stoplight/spectral-documentation": "^1.3.1",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@quobix/vacuum": "^0.20.4",
    "@swc/core": "^1.15.3",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "cpx2": "^9.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "js-yaml": "^4.2.0",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-renumber-references": "^3.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0"
  }
}
